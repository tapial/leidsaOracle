# LeidsaOracle Environment Configuration
# Copy this file to .env and adjust values

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://leidsa:leidsa_dev@localhost:5432/leidsa_oracle
DB_PASSWORD=leidsa_dev

# Scraper
LEIDSA_SCRAPER_BASE_URL=https://loteriasdominicanas.com
LEIDSA_SCRAPER_FALLBACK_URL=https://www.conectate.com.do
LEIDSA_SCRAPER_TIMEOUT=30
LEIDSA_SCRAPER_MAX_RETRIES=3
LEIDSA_SCRAPER_DELAY=1.0

# Game config
LEIDSA_DEFAULT_GAME=loto

# Analytics
LEIDSA_MONTE_CARLO_ITERATIONS=100000
LEIDSA_CANDIDATE_POOL_SIZE=5000
LEIDSA_FINAL_COMBINATION_COUNT=10
LEIDSA_MIN_HAMMING_DISTANCE=3

# API
LEIDSA_API_HOST=0.0.0.0
LEIDSA_API_PORT=8000
LEIDSA_CORS_ORIGINS=["*"]

# Streamlit
STREAMLIT_PORT=8501
